pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/tallurisravya6618-pixel/Three-dev-aws.git'
            }
        }

        stage('Install Backend Dependencies (No package.json)') {
            steps {
                sh '''
                    node -v
                    npm -v

                    npm init -y
                    npm install express cors
                '''
            }
        }

        stage('Install PM2') {
            steps {
                sh '''
                    sudo npm install -g pm2
                '''
            }
        }

        stage('Start Backend with PM2') {
            steps {
                sh '''
                    pm2 delete app || true
                    pm2 start server.js --name app
                    pm2 save
                '''
            }
        }

        stage('Check Frontend Folder') {
            steps {
                sh '''
                    ls -la
                '''
            }
        }

        stage('Build Frontend (if exists)') {
            steps {
                sh '''
                    if [ -d "frontend" ]; then
                        cd frontend
                        npm install
                        npm run build
                    else
                        echo "Frontend folder not found - skipping build"
                    fi
                '''
            }
        }

        stage('Deploy Frontend') {
            steps {
                sh '''
                    if [ -d "frontend/build" ]; then
                        sudo rm -rf /var/www/html/* || true
                        sudo cp -r frontend/build/* /var/www/html/ || true
                    else
                        echo "No build folder found - skipping deploy"
                    fi
                '''
            }
        }
    }
}
