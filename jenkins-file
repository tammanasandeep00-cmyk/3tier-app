pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git(
                    branch: 'main',
                    url: 'https://github.com/tallurisravya6618-pixel/Three-dev-aws.git'
                )
            }
        }

        stage('Install NodeJS and npm') {
            steps {
                sh '''
                    sudo dnf update -y
                    sudo dnf install nodejs npm -y

                    node -v
                    npm -v
                '''
            }
        }

        stage('Build Frontend') {
            steps {
                sh '''
                    npm install
                    npm run build
                '''
            }
        }
    }
}
