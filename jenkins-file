pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/tallurisravya6618-pixel/Three-dev-aws.git'
            }
        }

        stage('Install Node Modules Manually') {
            steps {
                sh '''
                    node -v
                    npm -v

                    # initialize project (creates temporary package.json in workspace)
                    npm init -y

                    # install dependencies directly
                    npm install express cors
                '''
            }
        }

        stage('Run Application') {
            steps {
                sh '''
                    nohup node server.js > app.log 2>&1 &
                '''
            }
        }
    }
}
