pipeline {
    agent any

    stages {

        stage('Install NodeJS on Amazon Linux') {
            steps {
                sh '''
                    sudo yum update -y

                    # Install NodeSource repository
                    curl -fsSL https://rpm.nodesource.com/setup_18.x | sudo bash -

                    # Install Node.js and npm
                    sudo yum install -y nodejs

                    # Verify installation
                    node -v
                    npm -v
                '''
            }
        }

        stage('Clone Code') {
            steps {
                git(
                    branch: 'main',
                    url: 'https://github.com/tallurisravya6618-pixel/Three-dev-aws.git'
                )
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                sh 'npm install'
            }
        }
    }
}
