pipeline {
  agent any

  stages {
    stage('Checkout') {
      steps {
        git 'https://github.com/your-repo.git'
      }
    }

    stage('Build Docker') {
      steps {
        sh 'docker build -t myapp .'
      }
    }

    stage('Run Container') {
      steps {
        sh 'docker run -d -p 3000:3000 myapp || true'
      }
    }
  }
}
